---
---
<section class="section" id="access">
  <h2 class="section-title">[ ACCESS ]</h2>
  <div class="access-wrap">
    <div class="card access-info">
      <dl>
        <div class="dl-row">
          <dt>所在地</dt>
          <dd>徳島県名西郡神山町神領字中津121-4</dd>
        </div>
        <div class="dl-row">
          <dt>最寄バス停</dt>
          <dd>神山温泉前（徳島駅よりバス約80分）</dd>
        </div>
        <div class="dl-row">
          <dt>徳島空港から</dt>
          <dd>車で約60分</dd>
        </div>
        <div class="dl-row">
          <dt>JR石井駅から</dt>
          <dd>バスで約40分</dd>
        </div>
      </dl>
    </div>
    <div class="map-frame">
      <iframe
        title="神山まるごと高専 地図"
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3274.3!2d134.09!3d33.98!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x35531d8b6a000001%3A0x1!2z56We5bGx44G+44KL44GU44Go9ad96eSB5LiL5LiH5Lil5a6H5qWt5a2j5a2Q!5e0!3m2!1sja!2sjp!4v1700000000000!5m2!1sja!2sjp"
        width="100%"
        height="380"
        style="border:0;"
        allowfullscreen
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
      ></iframe>
    </div>
  </div>
</section>

<style>
.access-wrap {
  display: grid;
  grid-template-columns: 1fr 1.6fr;
  gap: 2rem;
  align-items: start;
}

@media (max-width: 720px) {
  .access-wrap { grid-template-columns: 1fr; }
}

.access-info dl {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.dl-row {
  border-bottom: 1px dashed #d4b8f0;
  padding-bottom: 0.8rem;
}

.dl-row dt {
  font-family: var(--font-y2k);
  font-size: 1.1rem;
  letter-spacing: 0.08em;
  color: #8b5cf6;
  margin-bottom: 0.15rem;
}

.dl-row dd {
  font-size: 0.93rem;
  color: var(--text-mid);
  line-height: 1.7;
}

.map-frame {
  border-radius: 16px;
  overflow: hidden;
  border: 1.5px solid var(--accent);
  box-shadow: 0 4px 24px var(--glow);
}
</style>
